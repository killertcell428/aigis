# ============================================================
# Aigis — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aigis

# --- Backend ---
SECRET_KEY=CHANGE_ME_USE_A_STRONG_RANDOM_32_CHAR_SECRET
DEBUG=false
ENVIRONMENT=production

# --- Upstream LLM ---
# The API key your tenants will use to forward requests to the real LLM.
# In a multi-tenant setup, tenants provide their own keys.
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Review SLA ---
REVIEW_SLA_MINUTES=30
REVIEW_SLA_FALLBACK=block   # block | allow | escalate

# --- Risk thresholds (global defaults, overridden per-tenant policy) ---
AUTO_ALLOW_THRESHOLD=30
AUTO_BLOCK_THRESHOLD=81
